			"item": [
				{
					"name": "Логин demo-пользователя",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const json = pm.response.json();",
									"pm.collectionVariables.set('userToken', json.token);",
									"",
									"pm.test('Логин успешен', () => {",
									"    pm.response.to.have.status(200);",
									"    pm.expect(json.token).to.be.a('string');",
									"    pm.expect(json.user.email).to.eql('demo@nk.ru');",
									"});",
									"",
									"pm.test('Роль = user', () => {",
									"    pm.expect(json.user.role).to.eql('user');",
									"});",
									"",
									"pm.test('Бонусы = 250', () => {",
									"    pm.expect(json.user.points).to.eql(250);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"demo@nk.ru\",\n    \"password\": \"demo1234\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "login"]
						}
					}
				},
